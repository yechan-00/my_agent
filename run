#!/usr/bin/env bash
# 어디서 실행하든 OK:  ./run   또는   bash /전체/경로/my_agent/run
# bash로 실행할 때 zsh ~/.zshrc PATH가 안 잡히는 경우가 있어 흔한 설치 경로를 앞에 둡니다.
set -e
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
export PATH="${HOME}/.local/bin:${HOME}/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"
if ! command -v uv >/dev/null 2>&1; then
  echo "uv 를 찾을 수 없습니다. 터미널에서 'which uv' 로 경로를 확인하거나 설치: https://docs.astral.sh/uv/" >&2
  echo "또는:  export PATH=\"/opt/homebrew/bin:\$PATH\"   (Apple Silicon Homebrew)" >&2
  exit 1
fi
exec uv run --project "$ROOT" my-agent -e "$@"
